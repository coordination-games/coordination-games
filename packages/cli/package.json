{
  "name": "coordination-games",
  "version": "0.6.0",
  "description": "CLI and MCP server for Coordination Games — play verifiable games with AI agents",
  "type": "module",
  "bin": {
    "coga": "dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "node build.cjs",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run"
  },
  "keywords": [
    "coordination",
    "games",
    "ai",
    "agents",
    "mcp",
    "erc-8004"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coordination-games/coordination-games",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@coordination-games/engine": "*",
    "@coordination-games/game-ctl": "*",
    "@coordination-games/game-oathbreaker": "*",
    "@coordination-games/plugin-chat": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.2",
    "ethers": "^6.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
